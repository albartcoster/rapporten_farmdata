<<grafiek,echo = FALSE,results = hide>>=
Prod <- prod[prod$DATUM==max(prod$DATUM)&prod$DILcat>0,]
iis <- c(30,60,200)
xls <- c('0-30' = 15,'31-60'= 45,'61-200'=130,'>200'= 282.5)
Prod$NLACTcat <- factor(Prod$NLACTcat)
levels(Prod$NLACTcat) <- c("alle dieren","1e lact.","2e lact.","3+ lact.")

pplot <- with(Prod,xyplot(PROD_KG~DIL|NLACTcat,
                          main = paste('Overzicht van melkproductie tot 365 dagen in lactatie op',unique(DATUM[!is.na(DATUM)])),
                          layout = c(2,2),as.table = TRUE,
                          xlim = c(0,350),ylim = c(0,60),
                          xlab = "Dagen in lactatie",ylab = "Productie (kg/dag)",
                          axis = axis.CL,strip = strip.combined,
                          scales = list(alternating = FALSE,
                          x = list(labels = names(xls),at = xls,rot = 45)),
                          panel = function(x,y,groups,color,...,subscripts){
                              panel.abline(v = iis,col.line = 'grey')
                              panel.abline(h = 50,col.line = 'grey')
                              panel.xyplot(x,y,col = 'red',fill = 'red',pch = 22,...)
                              tt <- data.frame(y = y,DIL = x,DILe = exp(-0.05*x))
                              X <- seq(1,350)
                              a <- parameters$waarde[which(parameters$groep == unique(Prod$NLACTcat[subscripts])&
                                         parameters$parameter == 'a'&
                                         parameters$datum == unique(Prod$DATUM[subscripts]))]
                              b <- parameters$waarde[which(parameters$groep == unique(Prod$NLACTcat[subscripts])&
                                         parameters$parameter == 'b'&
                                         parameters$datum == unique(Prod$DATUM[subscripts]))]
                              c <- parameters$waarde[which(parameters$groep == unique(Prod$NLACTcat[subscripts])&
                                         parameters$parameter == 'c'&
                                         parameters$datum == unique(Prod$DATUM[subscripts]))]
                              panel.lines(X,a + X*b + c*exp(-0.05*X),col = 'blue',
                                          lwd = 2,lty = 2,col.line = 'blue')
                          }))
pdf("prod.pdf",width = 10,height = 8)
print(pplot)
graphics.off()
@

