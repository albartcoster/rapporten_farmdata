<<celgetalHoog,echo = FALSE,results = tex>>=
nle <- function(x)
    paste(sum(x,na.rm = TRUE)," (",length(x),")",sep = "")
percle <- function(x)
    paste(round(sum(x,na.rm = TRUE)/length(x[!is.na(x)])*100,0)," (",length(x),")",sep = "")
prod$CELHOOG <- with(prod,ifelse(NLACT == 1,CELGETAL > 150,CELGETAL >250))
tabCelHoog <- melt(with(prod[!is.na(prod$CELHOOG),],tapply(CELHOOG,list(NLACTcat,DILcat,DATUM),percle)))
tabCelHoog <- tabCelHoog[!is.na(tabCelHoog$value),]
tabCelHoog <- cast(tabCelHoog,X1 + X2~X3)
tabCelHoog$X1 <- factor(tabCelHoog$X1)
levels(tabCelHoog$X1) <- c("Alle lactaties","1e lact.","2e lact.","3+ lact.")
tabCelHoog$X1 <- as.character(tabCelHoog$X1)
tabCelHoog$X2 <- factor(tabCelHoog$X2)
levels(tabCelHoog$X2) <- lstats
tabCelHoog$X2 <- as.character(tabCelHoog$X2)
colnames(tabCelHoog)[1:2] <- c("NLACT","DIL")
tabCelHoog[is.na(tabCelHoog)] <- ""
latex(tabCelHoog[,-1],file = "",title = "N. Lact",first.hline.double = FALSE,where = "!h",
      rowname = "",
      rgroup = unique(tabCelHoog$NLACT),n.rgroups = tapply(tabCelHoog$NLACT,tabCelHoog$NLACT,length),
      caption = "\\captiontabCelHoog")
@

<<verlies,echo = FALSE,results = tex>>=
tabDiff <- melt(with(prod[!is.na(prod$CELHOOG),],tapply(seq(1:length(NLACTcat)),list(NLACTcat,DILcat,DATUM),function(x){
    CG <- CELGETAL[x]
    PD <- PROD_KG[x]
    mm <- median(CG,na.rm = T)
    pl <- mean(PD[CG>mm],na.rm = T)
    pm <- mean(PD[CG<mm],na.rm = T)
    diff <- round(mean(pm - pl,na.rm = T),2)
    mm <- round(mm,0)
    if(is.na(diff))
        return("")
    else
        return(paste(diff," (",mm,")",sep = ""))
})))
tabDiff <- tabDiff[!is.na(tabDiff$value),]
tabDiff <- cast(tabDiff,X1 + X2~X3)
tabDiff$X1 <- factor(tabDiff$X1)
levels(tabDiff$X1) <- c("Alle lactaties","1e lact.","2e lact.","3+ lact.")
tabDiff$X1 <- as.character(tabDiff$X1)
tabDiff$X2 <- factor(tabDiff$X2)
levels(tabDiff$X2) <- lstats
tabDiff$X2 <- as.character(tabDiff$X2)
colnames(tabDiff)[1:2] <- c("NLACT","DIL")
tabDiff[is.na(tabDiff)] <- ""
tabDiff <- tabDiff[with(tabDiff,!NLACT%in%'Alle lactaties'&!DIL%in%'Alle DIL'),]
latex(tabDiff[,-1],file = "",title = "N. Lact",first.hline.double = FALSE,where = "!h",
      rowname = "",
      rgroup = unique(tabDiff[,1]),n.rgroups = table(tabDiff[,1]),
      caption = "\\captiontabDiff")
@
