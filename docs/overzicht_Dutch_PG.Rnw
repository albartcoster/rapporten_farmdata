<<ureum,echo = FALSE,results = tex>>=
meanlep <- function(x,y,ndec = 2){
    nana <- !is.na(x)&!is.na(y)
    x <- x[nana]
    y <- y[nana]
    pmean <- sum(x*y)/sum(y)
    paste(format(round(pmean,ndec),nsmall = ndec)," (",length(x),")",sep = "")
}

if(nrow(prod[!is.na(prod$UREUM),])>0){
    tabUreum <- melt(with(prod[!is.na(prod$UREUM),],tapply(1:length(UREUM),list(NLACTcat,DILcat,DATUM),
                                                            function(x)meanlep(UREUM[x],PROD_KG[x],2))))
tabUreum <- tabUreum[!is.na(tabUreum$value),]
tabUreum <- cast(tabUreum,X1 + X2~X3)
tabUreum$X1 <- factor(tabUreum$X1)
levels(tabUreum$X1) <- c("Alle lactaties","1e lact.","2e lact.","3+ lact.")
tabUreum$X1 <- as.character(tabUreum$X1)
tabUreum$X2 <- factor(tabUreum$X2)
levels(tabUreum$X2) <- lstats
tabUreum$X2 <- as.character(tabUreum$X2)
colnames(tabUreum)[1:2] <- c("NLACT","DIL")
tabUreum[is.na(tabUreum)] <- ""
latex(tabUreum[,-1],file = "",title = "N. Lact",first.hline.double = FALSE,where = "!h",
      rowname = "",
      rgroup = unique(tabUreum$NLACT),n.rgroups = tapply(tabUreum$NLACT,tabUreum$NLACT,length),
      caption = "\\captiontabUreum")
}
