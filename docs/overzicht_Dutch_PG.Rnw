<<eiwitgehalte,echo = FALSE,results = tex>>=
meanlep <- function(x,y,ndec = 2){
    nana <- !is.na(x)&!is.na(y)
    x <- x[nana]
    y <- y[nana]
    pmean <- sum(x*y)/sum(y)
    paste(format(round(pmean,ndec),nsmall = ndec)," (",length(x),")",sep = "")
}


tabEiwit <- melt(with(prod[!is.na(prod$EIWIT_PERC),],tapply(1:length(EIWIT_PERC),list(NLACTcat,DILcat,DATUM),
                                                            function(x)meanlep(EIWIT_PERC[x],PROD_KG[x],2))))
tabEiwit <- tabEiwit[!is.na(tabEiwit$value),]
tabEiwit <- cast(tabEiwit,X1 + X2~X3)
tabEiwit$X1 <- factor(tabEiwit$X1)
levels(tabEiwit$X1) <- c("Alle lactaties","1e lact.","2e lact.","3+ lact.")
tabEiwit$X1 <- as.character(tabEiwit$X1)
tabEiwit$X2 <- factor(tabEiwit$X2)
levels(tabEiwit$X2) <- lstats
tabEiwit$X2 <- as.character(tabEiwit$X2)
colnames(tabEiwit)[1:2] <- c("NLACT","DIL")
tabEiwit[is.na(tabEiwit)] <- ""
latex(tabEiwit[,-1],file = "",title = "N. Lact",first.hline.double = FALSE,where = "!h",
      rowname = "",
      rgroup = unique(tabEiwit$NLACT),n.rgroups = tapply(tabEiwit$NLACT,tabEiwit$NLACT,length),
      caption = "\\captiontabEiwit")
